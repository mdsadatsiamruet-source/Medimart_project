<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/bg_revenue"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SALES &amp; REVENUE"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#B3E5FC"
        android:layout_marginBottom="40dp"
        android:shadowColor="#000000"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="3"/>

    <TextView
        android:id="@+id/todaySalesText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="25dp"
        android:text="Today's Total Revenue: $0"
        android:textColor="#81C784"
        android:background="#AA000000"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"
        android:gravity="center" />

    <Button
        android:id="@+id/btnRefreshSales"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Refresh Today's Sales"
        android:backgroundTint="#2196F3"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp" />

    <Button
        android:id="@+id/btnCloseDay"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:backgroundTint="#D32F2F"
        android:text="Close Day (Reset View)"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp" />

    <Button
        android:id="@+id/btnHistoricalTotal"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:backgroundTint="#1976D2"
        android:text="Show Total Historical Revenue"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp" />

    <TextView
        android:id="@+id/historicalTotalText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="25dp"
        android:text="Combined Total: $0"
        android:textColor="#FFFFFF"
        android:background="#AA000000"
        android:textSize="20sp"
        android:gravity="center" />

</LinearLayout>